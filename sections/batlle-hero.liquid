{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .batlle-hero {
    position: relative;
    min-height: calc(100vh - var(--header-height, 90px) + 2rem + 50px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 0;
  }

  .batlle-hero__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 4.5rem;
    align-items: center;
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .batlle-hero__grid {
      flex-wrap: nowrap;
      gap: 8rem;
    }
  }

  .batlle-hero__content {
    flex: 0 0 auto;
    max-width: 50%;
    position: relative;
  }

  .batlle-hero__visual {
    flex: 0 0 auto;
    padding-top: 1.5rem;
  }

  .batlle-hero__supertitle {
    font-family: var(--font-body-family);
    font-size: 1.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.5);
    margin-bottom: 2.25rem;
  }

  .batlle-hero__title {
    font-family: var(--font-heading-family);
    font-size: clamp(5.4rem, 13.5vw, 12rem);
    line-height: 0.9;
    letter-spacing: 0.04em;
    font-weight: var(--font-heading-weight);
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .batlle-hero__subtitle {
    font-family: var(--font-heading-family);
    font-size: clamp(2.7rem, 6.75vw, 4.7rem);
    font-weight: var(--font-heading-weight);
    line-height: 1;
    font-style: italic;
    margin: 0.75rem 0 2.25rem;
    color: rgb(var(--color-foreground));
  }

  .batlle-hero__description {
    font-size: 1.6rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
    max-width: 48rem;
    margin-bottom: 3.75rem;
  }

  .batlle-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2.25rem;
  }

  .batlle-hero__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 1.1rem;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    padding: 1.8rem 3.6rem;
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .batlle-hero__cta-primary:hover {
    opacity: 0.85;
  }

  .batlle-hero__cta-primary-arrow {
    transition: transform 0.3s ease;
  }

  .batlle-hero__cta-primary:hover .batlle-hero__cta-primary-arrow {
    transform: translateX(3px);
  }

  .batlle-hero__cta-secondary {
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.4);
    padding-bottom: 0.45rem;
    transition: border-color 0.3s ease;
  }

  .batlle-hero__cta-secondary:hover {
    border-color: rgb(var(--color-foreground));
  }

  .batlle-hero__visual {
    position: relative;
  }

  .batlle-hero__image-wrapper {
    position: relative;
    aspect-ratio: 2 / 3;
    max-width: 42rem;
    margin: 0 auto;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.08);
  }

  @media screen and (min-width: 990px) {
    .batlle-hero__image-wrapper {
      margin-left: auto;
    }
  }

  .batlle-hero__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .batlle-hero__overlay-card {
    position: absolute;
    bottom: -2.25rem;
    left: -2.25rem;
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.15);
    padding: 1.5rem 2.25rem;
    max-width: 21rem;
    box-shadow: 0 3px 18px rgba(0, 0, 0, 0.04);
  }

  @media screen and (min-width: 990px) {
    .batlle-hero__overlay-card {
      left: -4.5rem;
    }
  }

  .batlle-hero__overlay-number {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.5);
    margin-bottom: 0.45rem;
  }

  .batlle-hero__overlay-name {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    line-height: 1.15;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  .batlle-hero__overlay-materials {
    font-size: 1.8rem;
    color: rgba(var(--color-foreground), 0.6);
    font-style: italic;
    margin-top: 0.45rem;
  }

  .batlle-hero__scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.4);
    animation: batlle-scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes batlle-scroll-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  @media screen and (max-width: 989px) {
    .batlle-hero {
      min-height: auto;
      padding: 5rem 0 4rem;
    }

    .batlle-hero__grid {
      flex-direction: column;
      text-align: center;
      gap: 3rem;
    }

    .batlle-hero__content {
      max-width: 100%;
      order: 1;
    }

    .batlle-hero__visual {
      order: 2;
      padding-top: 0;
      width: 100%;
    }

    .batlle-hero__image-wrapper {
      margin: 0 auto;
      max-width: 32rem;
    }

    .batlle-hero__title {
      font-size: clamp(3.5rem, 12vw, 7rem);
    }

    .batlle-hero__subtitle {
      font-size: clamp(2rem, 5vw, 3rem);
      margin: 0.5rem 0 1.5rem;
    }

    .batlle-hero__supertitle {
      font-size: 1.2rem;
      margin-bottom: 1.5rem;
    }

    .batlle-hero__description {
      font-size: 1.4rem;
      max-width: 28rem;
      margin-left: auto;
      margin-right: auto;
    }

    .batlle-hero__ctas {
      justify-content: center;
    }

    .batlle-hero__cta-primary {
      padding: 1.2rem 2.4rem;
      font-size: 1.2rem;
    }

    .batlle-hero__cta-secondary {
      font-size: 1.2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .batlle-hero {
      padding: 3rem 0 3rem;
    }

    .batlle-hero__title {
      font-size: clamp(2.8rem, 10vw, 5rem);
    }

    .batlle-hero__subtitle {
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      margin: 0.3rem 0 1rem;
    }

    .batlle-hero__supertitle {
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .batlle-hero__image-wrapper {
      max-width: 32rem;
    }

    .batlle-hero__overlay-card {
      bottom: -1rem;
      left: -0.5rem;
      max-width: 14rem;
      padding: 0.8rem 1.2rem;
    }

    .batlle-hero__overlay-name {
      font-size: 1.6rem;
    }

    .batlle-hero__overlay-number {
      font-size: 1rem;
    }

    .batlle-hero__overlay-materials {
      font-size: 1.2rem;
    }

    .batlle-hero__description {
      font-size: 1.3rem;
      max-width: 24rem;
      margin-bottom: 1.5rem;
    }

    .batlle-hero__scroll-hint {
      font-size: 1.1rem;
      bottom: 0.5rem;
    }
  }
</style>

<div class="batlle-hero color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="page-width batlle-hero__grid section-{{ section.id }}-padding">
    <div class="batlle-hero__content">
      {%- if section.settings.supertitle != blank -%}
        <p class="batlle-hero__supertitle">{{ section.settings.supertitle }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="batlle-hero__title">{{ section.settings.title }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="batlle-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="batlle-hero__description">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      <div class="batlle-hero__ctas">
        {%- if section.settings.cta_1_label != blank and section.settings.cta_1_link != blank -%}
          <a href="{{ section.settings.cta_1_link }}" class="batlle-hero__cta-primary">
            {{ section.settings.cta_1_label }}
            <span class="batlle-hero__cta-primary-arrow">→</span>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_2_label != blank and section.settings.cta_2_link != blank -%}
          <a href="{{ section.settings.cta_2_link }}" class="batlle-hero__cta-secondary">
            {{ section.settings.cta_2_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="batlle-hero__visual">
      <div class="batlle-hero__image-wrapper">
        {%- if section.settings.hero_image != blank -%}
          {%- assign image_height = section.settings.hero_image.width | divided_by: section.settings.hero_image.aspect_ratio -%}
          {{
            section.settings.hero_image
            | image_url: width: 1024
            | image_tag:
              width: 1024,
              height: image_height,
              sizes: '(min-width: 990px) 50vw, 100vw',
              widths: '375, 550, 750, 1024',
              loading: 'eager'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.overlay_piece_title != blank -%}
          <div class="batlle-hero__overlay-card">
            {%- if section.settings.overlay_piece_number != blank -%}
              <p class="batlle-hero__overlay-number">{{ section.settings.overlay_piece_number }}</p>
            {%- endif -%}
            <p class="batlle-hero__overlay-name">{{ section.settings.overlay_piece_title }}</p>
            {%- if section.settings.overlay_piece_materials != blank -%}
              <p class="batlle-hero__overlay-materials">{{ section.settings.overlay_piece_materials }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="batlle-hero__scroll-hint">↓ Faire défiler</div>
</div>

{% schema %}
{
  "name": "t:sections.batlle-hero.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "supertitle",
      "default": "Maison Batlle · Paris · Édition 01",
      "label": "t:sections.batlle-hero.settings.supertitle.label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "BATLLE",
      "label": "t:sections.batlle-hero.settings.title.label"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "l'armure d'une femme.",
      "label": "t:sections.batlle-hero.settings.subtitle.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "default": "<p>Pièces sur-mesure inspirées des chevaleresses, des sorcières et des figures puissantes de l'histoire. Confection main à Paris.</p>",
      "label": "t:sections.batlle-hero.settings.description.label"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "t:sections.batlle-hero.settings.hero_image.label"
    },
    {
      "type": "text",
      "id": "overlay_piece_number",
      "default": "Pièce N° 01",
      "label": "t:sections.batlle-hero.settings.overlay_piece_number.label"
    },
    {
      "type": "text",
      "id": "overlay_piece_title",
      "default": "L'Armure de Jeanne",
      "label": "t:sections.batlle-hero.settings.overlay_piece_title.label"
    },
    {
      "type": "text",
      "id": "overlay_piece_materials",
      "default": "Cuir, métal, soie noire",
      "label": "t:sections.batlle-hero.settings.overlay_piece_materials.label"
    },
    {
      "type": "text",
      "id": "cta_1_label",
      "default": "Voir la collection",
      "label": "t:sections.batlle-hero.settings.cta_1_label.label"
    },
    {
      "type": "text",
      "id": "cta_1_link",
      "default": "#batlle-collection",
      "label": "t:sections.batlle-hero.settings.cta_1_link.label"
    },
    {
      "type": "text",
      "id": "cta_2_label",
      "default": "Découvrir l'e-shop",
      "label": "t:sections.batlle-hero.settings.cta_2_label.label"
    },
    {
      "type": "text",
      "id": "cta_2_link",
      "default": "#batlle-eshop",
      "label": "t:sections.batlle-hero.settings.cta_2_link.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Remplissage mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Remplissage haut mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Remplissage bas mobile",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:sections.batlle-hero.presets.name"
    }
  ]
}
{% endschema %}
