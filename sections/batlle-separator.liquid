{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .batlle-separator__line {
    border: none;
    border-top: {{ section.settings.line_width }}px solid rgba(var(--color-foreground), 0.15);
    width: {{ section.settings.line_length }}%;
    margin: 0 auto;
  }

  .batlle-separator__text {
    text-align: center;
    margin-top: 1.5rem;
    font-family: var(--font-body-family);
    font-size: 1.05rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.5);
  }
{%- endstyle -%}

<div class="batlle-separator color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="batlle-separator__line" aria-hidden="true"></div>
    {%- if section.settings.text != blank and section.settings.text != '·' -%}
      <p class="batlle-separator__text">{{ section.settings.text }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Séparateur BATLLE",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "·",
      "label": "Texte (optionnel, effacer le point pour désactiver)"
    },
    {
      "type": "range",
      "id": "line_width",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Épaisseur du trait",
      "default": 1
    },
    {
      "type": "range",
      "id": "line_length",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Longueur du trait",
      "default": 85
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "header",
      "content": "Remplissage mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Remplissage haut mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Remplissage bas mobile",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Séparateur BATLLE"
    }
  ]
}
{% endschema %}
